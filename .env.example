# Required: your LLM provider API key
LLMCALL_API_KEY=sk-...

# Optional: model to use (default: openai/gpt-4o-2024-08-06)
# Uses LiteLLM provider/model format — see https://docs.litellm.ai/docs/providers
# Examples:
#   openai/gpt-4o-mini
#   anthropic/claude-3-5-haiku-20241022
#   groq/llama-3.3-70b-versatile
#   ollama/llama3.2
LLMCALL_MODEL=openai/gpt-4o-2024-08-06

# Optional: custom base URL for OpenAI-compatible endpoints (Ollama, Azure, LM Studio, etc.)
# LLMCALL_BASE_URL=http://localhost:11434

# Optional: enable debug logging (default: false)
# LLMCALL_DEBUG=true
